\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{apstats-boxes}[2026/06/01 AP Statistics tcolorbox environments]

% Requires colors and tcolorbox; does NOT require apstats-article so that
% lesson-plan documents can set their own geometry independently.
\RequirePackage{apstats-colors}
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{breakable, skins}

% ── Lesson-plan box ───────────────────────────────────────────────────────────
% Usage: \begin{skillbox}[Title]{background-color} ... \end{skillbox}
\newtcolorbox{skillbox}[2][]{
    colback=#2, colframe=navy, boxrule=0.8pt, arc=2mm,
    left=2mm, right=2mm, top=1.5mm, bottom=1.5mm,
    fonttitle=\bfseries, title={#1}, halign title=center, breakable
}

% ── Objective / learning-target boxes ─────────────────────────────────────────
\newtcolorbox{objectivebox}{
    enhanced,
    colback=sky, colframe=navy, boxrule=1pt, arc=2mm,
    left=3mm, right=3mm, top=2mm, bottom=2mm,
    fonttitle=\bfseries\small\color{white}, title={Primary Objective},
    attach boxed title to top left={yshift=-2mm, xshift=4mm},
    boxed title style={colback=navy, colframe=navy, arc=1.5mm}
}
\newtcolorbox{learningtargetbox}{
    enhanced,
    colback=sky, colframe=navy, boxrule=1pt, arc=2mm,
    left=3mm, right=3mm, top=2mm, bottom=2mm,
    fonttitle=\bfseries\small\color{white},
    title={Learning Targets --- I Can\dots},
    attach boxed title to top left={yshift=-2mm, xshift=4mm},
    boxed title style={colback=navy, colframe=navy, arc=1.5mm}
}

