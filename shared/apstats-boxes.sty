% ── Reusable component identification table (student version) ─────────────────
% Usage: \componenttable  (no arguments; blanks for students to fill in)
\newcommand{\componenttable}{%
    \renewcommand{\arraystretch}{2.0}%
    \begin{tabularx}{\linewidth}{@{} >{\bfseries\color{navy}}p{0.22\linewidth} X @{}}
    Individual:  & \blank{10.5cm} \\
    Population:  & \blank{10.5cm} \\
    Sample:      & \blank{10.5cm} \\
    Variable(s): & \blank{10.5cm} \\
    \end{tabularx}}
