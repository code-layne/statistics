\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{apstats-key}[2026/06/01 AP Statistics answer-key additions]

\RequirePackage{apstats-boxes}

% ── Answer macros ─────────────────────────────────────────────────────────────
% \ans{text}      — inline answer (colored bold); replaces blanks or write lines
% \ansline{text}  — answer that fills a full write line with a dotted trail
\newcommand{\ans}[1]{\textcolor{keyred}{\textbf{#1}}}
\newcommand{\ansline}[1]{%
    \vspace{1pt}\noindent\textcolor{keyred}{\textbf{#1}}%
    \textcolor{linegray}{\dotfill}\vspace{3pt}}

% ── Component identification table (key version) ──────────────────────────────
% Usage: \componenttablekey{individual}{population}{sample}{variable(s)}
\newcommand{\componenttablekey}[4]{%
    \renewcommand{\arraystretch}{1.8}%
    \begin{tabularx}{\linewidth}{@{} >{\bfseries\color{navy}}p{0.22\linewidth} X @{}}
    Individual:  & \ans{#1} \\
    Population:  & \ans{#2} \\
    Sample:      & \ans{#3} \\
    Variable(s): & \ans{#4} \\
    \end{tabularx}}

% ── Teacher note box ──────────────────────────────────────────────────────────
\newtcolorbox{teachernote}{
    enhanced,
    colback=redbg, colframe=redacc, boxrule=0.7pt, arc=1.5mm,
    left=2mm, right=2mm, top=1.5mm, bottom=1.5mm,
    fonttitle=\bfseries\scriptsize\color{white}, title={Teacher Note},
    attach boxed title to top left={yshift=-2mm, xshift=4mm},
    boxed title style={colback=redacc, colframe=redacc, arc=1mm}
}
